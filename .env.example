# LLM providers — заполняем перед стартом модуля 02.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local infra (поднимается docker compose).
# pragma: allowlist secret — учебный пароль app:app, не сканировать как утечку.
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/app
REDIS_URL=redis://localhost:6379/0

# Опциональные сервисы — раскомментируем по мере появления.
# QDRANT_URL=http://localhost:6333
# LANGFUSE_HOST=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=

ENV=local
LOG_LEVEL=INFO
